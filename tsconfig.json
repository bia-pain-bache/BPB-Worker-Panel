{
    "include": ["src"],
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "types": ["@cloudflare/workers-types", "node"],
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "paths": {
            "@cores/*": ["./src/cores/*"],
            "@xray/*": ["./src/cores/xray/*"],
            "@sing-box/*": ["./src/cores/sing-box/*"],
            "@clash/*": ["./src/cores/clash/*"],
            "@utils": ["./src/cores/utils"],
            "@handlers/*": ["./src/handlers/*"],
            "@settings": ["./src/settings/settings"],
            "@validators": ["./src/settings/validators"],
            "@common": ["./src/common/common"],
            "@kv": ["./src/settings/kv"],
            "@main": ["./src/settings/main"],
            "@api/*": ["./src/api/*"],
            "@protocols/*": ["./src/protocols/*"],
            "@auth": ["./src/auth/auth"],
            "@workers": ["./src/workers"],
            "#types/*": ["./src/types/*"]
        }
    }
}
